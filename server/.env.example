# =============================================
# LOCAL STORE E-COMMERCE - SERVER ENV TEMPLATE
# =============================================
# Copy this file as .env and fill in your actual values

# ---- App Config ----
NODE_ENV=development
PORT=5000

# ---- MongoDB Atlas ----
MONGO_URI=mongodb+srv://<username>:<password>@cluster.xxxx.mongodb.net/dbname

# ---- JWT Secrets (use long random strings) ----
JWT_SECRET=your_jwt_access_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ---- Client URL (for CORS & reset password links) ----
CLIENT_URL=http://localhost:5173

# ---- Cloudinary (image storage) ----
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ---- Nodemailer (SMTP Email) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Local Store <your_email@gmail.com>"

# ---- Razorpay (Online Payment) ----
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
