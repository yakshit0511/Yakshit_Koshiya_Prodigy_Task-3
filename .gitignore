# =============================================
# Git Ignore — Local Store E-Commerce
# =============================================

# --- Node modules ---
node_modules/
**/node_modules/

# --- Environment files ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Build output ---
dist/
build/
.vite/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Editor specific ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Temporary / Upload folders ---
uploads/
temp/

# --- Coverage ---
coverage/
.nyc_output

# --- Misc ---
.cache/
.parcel-cache/
